---
// AABBDistanceDemo - interactive AABB distance visualisation
// Drag two rectangles to see how dx, dy, and euclidean distance change
---

<div class="aabb-demo" id="aabb-container">
  <span class="aabb-label" id="aabb-label"></span>
  <canvas id="aabb-canvas"></canvas>
</div>

<style>
  .aabb-demo {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    margin: 1.5rem 0;
    background: white;
    overflow: hidden;
  }

  #aabb-canvas {
    display: block;
    width: 100%;
    height: 100%;
    touch-action: none;
  }

  .aabb-label {
    position: absolute;
    top: 8px;
    left: 10px;
    font: 13px/1 monospace;
    color: rgba(0, 0, 0, 0.5);
    pointer-events: none;
    z-index: 1;
  }
</style>

<script>
  import { initAABBDistanceDemo } from '../../lib/toys/AABBDistanceDemo';
  initAABBDistanceDemo('aabb-container');
</script>
