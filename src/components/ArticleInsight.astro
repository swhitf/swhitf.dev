---
interface Props {
  title?: string;
}

const { title = "Insight" } = Astro.props;
---

<div class="w-full my-8">
  <div class="relative bg-amber-50 py-5 overflow-hidden">
    <div class="px-6 flex items-center gap-2 mb-2">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-amber-500 shrink-0">
        <path d="M9 21c0 .5.4 1 1 1h4c.6 0 1-.5 1-1v-1H9v1zm3-19C8.1 2 5 5.1 5 9c0 2.4 1.2 4.5 3 5.7V17c0 .5.4 1 1 1h6c.6 0 1-.5 1-1v-2.3c1.8-1.3 3-3.4 3-5.7 0-3.9-3.1-7-7-7z" />
      </svg>
      <span class="text-sm font-semibold text-amber-700 uppercase tracking-wide">{title}</span>
    </div>
    <div class="px-6 [&_p]:!mb-0 text-amber-900 [&_a]:text-amber-700">
      <slot />
    </div>
  </div>
</div>
