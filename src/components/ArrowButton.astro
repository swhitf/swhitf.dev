---
interface Props {
  label: string;
  left?: boolean;
}

const { label, left = false } = Astro.props;
---

<span class="text-accent-600 hover:text-accent-700 font-medium inline-flex items-center gap-2">
  {left && (
    <svg
      class="w-4 h-4 rotate-180"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M17 8l4 4m0 0l-4 4m4-4H3"
      />
    </svg>
  )}
  {label}
  {!left && (
    <svg
      class="w-4 h-4"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M17 8l4 4m0 0l-4 4m4-4H3"
      />
    </svg>
  )}
</span>
