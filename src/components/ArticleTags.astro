---
interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

{tags.length > 0 && (
  <>
    <span>•</span>
    <div class="flex gap-2">
      {tags.map((tag: string) => (
        <span class="px-2 py-1 bg-accent-500/20 text-accent-600 rounded-full text-sm">
          {tag}
        </span>
      ))}
    </div>
  </>
)}
