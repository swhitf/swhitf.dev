---
interface Props {
  title?: string;
}

const { title = "Note" } = Astro.props;
---

<div class="w-full my-8">
  <div class="relative bg-sky-50 py-5 overflow-hidden">
    <div class="px-6 flex items-center gap-2 mb-2">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 text-sky-500 shrink-0">
        <path fill-rule="evenodd" d="M18 10a8 8 0 1 1-16 0 8 8 0 0 1 16 0Zm-7-4a1 1 0 1 1-2 0 1 1 0 0 1 2 0ZM9 9a.75.75 0 0 0 0 1.5h.253a.25.25 0 0 1 .244.304l-.459 2.066A1.75 1.75 0 0 0 10.747 15H11a.75.75 0 0 0 0-1.5h-.253a.25.25 0 0 1-.244-.304l.459-2.066A1.75 1.75 0 0 0 9.253 9H9Z" clip-rule="evenodd" />
      </svg>
      <span class="text-sm font-semibold text-sky-700 uppercase tracking-wide">{title}</span>
    </div>
    <div class="px-6 [&_p]:!mb-0 text-sky-900 [&_a]:text-sky-700">
      <slot />
    </div>
  </div>
</div>
