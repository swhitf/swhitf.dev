---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ArrowButton from '../../components/ArrowButton.astro';
import ArticleDate from '../../components/ArticleDate.astro';
import ArticleTags from '../../components/ArticleTags.astro';
import profileImage from '../../assets/me-again.jpg';
//import '../../styles/blog.css';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog', ({ data }:any) => {
    return import.meta.env.PROD ? data.draft !== true : true;
  });
  return blogEntries.map((entry:any) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props as any;
const { Content } = await entry.render();
---

<Layout title={`${entry.data.title} - Steve Whitfield`}>
  <main>
    <article class="prose prose-md w-full max-w-none">
      <header class="border-t border-dashed border-gray-200">
        <div class="max-w-4xl mx-auto border-x border-gray-200 px-6 py-8">
          <h1>{entry.data.title}</h1>

        <div class="flex flex-wrap items-center gap-4 text-gray-500 text-base">
          <ArticleDate pubDate={entry.data.pubDate} updatedDate={entry.data.updatedDate} />
          {entry.data.tags && <ArticleTags tags={entry.data.tags} />}
        </div>

        {entry.data.description && (
          <p class="mb-2 text-xl text-gray-600 italic">
            {entry.data.description}
          </p>
        )}
        </div>
      </header>

      {entry.data.heroImage && (
        <img
          src={entry.data.heroImage}
          alt={entry.data.title}
          class="w-full rounded-xl mb-8 border border-gray-200"
        />
      )}

      <!-- Article Content -->
      <div class="border-t border-dashed border-gray-200">
        <div class="max-w-4xl mx-auto border-x border-gray-200 px-6 py-8">
        <Content />
      </div>
    </div>
      <!-- Author Sign-off -->
      <div class="border-t border-dashed border-gray-200">
        <div class="max-w-4xl mx-auto border-x border-gray-200 px-6 py-8">
          <div class="flex flex-col sm:flex-row gap-6 items-start">
            <img
              src={profileImage.src}
              alt="Steve Whitfield"
              class="w-20 h-20 object-cover border border-gray-200 flex-shrink-0"
            />
            <div class="text-gray-700 text-lg leading-relaxed">
              <p>Written by <strong>Steve Whitfield</strong>, co-founder of <a href="https://ludi.co" class="text-accent-500 underline hover:text-accent-600">Ludi</a> — a collaborative whiteboard for teams. You can <a href="https://ludi.co" class="text-accent-500 underline hover:text-accent-600">try it today for free</a>.</p>
            </div>
          </div>
        </div>
      </div>
    </article>
  </main>
</Layout>
